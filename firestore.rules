rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net default catch-all: deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate identifier strings (supports emails containing @ and .)
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Rules for Custom Users data storing
    match /chronos_users/{email} {
      allow get, list: if true;
      allow create, update: if isValidId(email)
        && request.resource.data.email is string
        && request.resource.data.password is string;
      allow delete: if false;
    }

    // Rules for User Game History
    match /users/{uid}/gameHistory/{gameId} {
      allow read, write: if true;
    }

    // Rules for Admin Config (SMTP and Email sender settings)
    match /config/auth {
      allow get, create, update: if true;
      allow delete: if false;
    }
  }
}
